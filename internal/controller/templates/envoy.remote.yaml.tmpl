admin:
  address:
    socket_address: { address: 0.0.0.0, port_value: 9901 }

static_resources:
  listeners:
  - name: ingress
    address:
      socket_address: { address: 0.0.0.0, port_value: 8080 }
    filter_chains:
    - filters:
      - name: envoy.filters.network.http_connection_manager
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
          stat_prefix: ingress_http
          codec_type: AUTO
          use_remote_address: false
          route_config:
            name: local
            virtual_hosts:
            - name: default
              domains: ["*"]
              routes:
              - match: { prefix: "/" }
                route:
                  cluster: remote
                  timeout: 0s
                  retry_policy:
                    retry_on: "5xx,gateway-error,connect-failure,refused-stream,reset"
                    num_retries: 2
                    per_try_timeout: 30s
          http_filters:
          - name: envoy.filters.http.router
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router

  - name: admin_proxy
    address:
      socket_address: { address: 0.0.0.0, port_value: 9902 }
    filter_chains:
    - filters:
      - name: envoy.filters.network.http_connection_manager
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
          stat_prefix: admin_proxy
          route_config:
            name: admin_local
            virtual_hosts:
            - name: admin
              domains: ["*"]
              routes:
              - match: { prefix: "/" }
                route:
                  cluster: admin_loopback
          http_filters:
          - name: envoy.filters.http.router
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router

  clusters:
  - name: remote
    connect_timeout: 3s
    type: STRICT_DNS
    dns_lookup_family: V4_ONLY
    dns_refresh_rate: 10s
    respect_dns_ttl: false
    lb_policy: {{ .LBPolicy }}
    ignore_health_on_host_removal: true
    {{- if .IsHTTPS }}
    transport_socket:
      name: envoy.transport_sockets.tls
      typed_config:
        "@type": type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.UpstreamTlsContext
        {{- if not .InsecureSkipVerify }}
        common_tls_context:
          validation_context:
            trust_chain_verification: VERIFY_TRUST_CHAIN
        {{- end }}
        {{- if .InsecureSkipVerify }}
        common_tls_context: {}
        {{- end }}
    {{- end }}
    health_checks:
    - timeout: 1s
      interval: 5s
      unhealthy_threshold: 2
      healthy_threshold: 1
      no_traffic_interval: 5s
      reuse_connection: false
      {{- if eq .HealthCheck.Type "HTTP" }}
      http_health_check:
        path: {{ .HealthCheck.HTTPPath | printf "%q" }}
        {{- if .HealthCheck.HTTPHost }}
        host: {{ .HealthCheck.HTTPHost | printf "%q" }}
        {{- end }}
      {{- else }}
      tcp_health_check: {}
      {{- end }}
    load_assignment:
      cluster_name: remote
      endpoints:
      {{- range $i, $g := .Groups }}
      - priority: {{ $i }}
        lb_endpoints:
        {{- range $g.Endpoints }}
        - endpoint:
            address:
              socket_address:
                address: {{ .Host | printf "%q" }}
                port_value: {{ .Port }}
            {{- if .Hostname }}
            hostname: {{ .Hostname | printf "%q" }}
            {{- end }}
        {{- end }}
      {{- end }}

  - name: admin_loopback
    connect_timeout: 1s
    type: STATIC
    lb_policy: ROUND_ROBIN
    load_assignment:
      cluster_name: admin_loopback
      endpoints:
      - lb_endpoints:
        - endpoint:
            address:
              socket_address: { address: 127.0.0.1, port_value: 9901 }
