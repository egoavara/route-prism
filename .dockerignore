# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include embedded template files (//go:embed targets such as the nginx
# translator template). The Tilt dev-loop image doesn't compile inside the
# container so this only matters for `make docker-build`, but if it's
# missing the in-container compile fails with: pattern <…>.tmpl: no
# matching files found.
!**/*.tmpl

# Re-include Go module files
!go.mod
!go.sum

# Re-include host-compiled binaries used by the Tilt dev-loop images.
!bin/manager-linux
!bin/sample-tier-linux

# Re-include web sources consumed by the web-builder stage in Dockerfile.
# Keep node_modules, vite caches and prebuilt dist directories out of the
# build context so the in-container build is reproducible.
!web/**
web/**/node_modules
web/**/node_modules/**
web/**/.vite
web/**/.vite/**
web/dist
web/dist/**
web/widget/dist
web/widget/dist/**
