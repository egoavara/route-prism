# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/*
modules/operator/bin/*
Dockerfile.cross

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Go workspace file
go.work

# Kubernetes Generated files - skip generated files, except for vendored files
!vendor/**/zz_generated.*

# editor and IDE paraphernalia
.idea
.vscode
*.swp
*.swo
*~

# Kubeconfig might contain secrets
*.kubeconfig

# Node / web modules
node_modules/
**/node_modules/
**/.vite/

# Embedded web bundles (regenerated by web-dashboard / web-widget compile).
# Directories are created on first `moon run` invocation; not tracked.
modules/operator/internal/dashboard/dist/
modules/operator/internal/widget/dist/

# moon caches
.moon/cache/
.moon/docker/

# Local build output. Release artifacts staged here by CI.
dist/
modules/operator/dist/

# Git worktrees and sibling clones (e.g. .worktree/.wiki for the GitHub wiki).
.worktree/

# Local agent configuration file
AGENTS.local.md
CLAUDE.local.md
